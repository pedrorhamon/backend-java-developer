# Force LF line endings for shell scripts — critical for Docker (Alpine Linux)
mvnw text eol=lf
*.sh text eol=lf

# Windows-style files
*.bat text eol=crlf
*.cmd text eol=crlf

# Text files — normalize on commit
*.java text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.xml  text eol=lf
*.sql  text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.properties text eol=lf

# Binary files — no conversion
*.jar  binary
*.png  binary
*.jpg  binary
*.gif  binary
